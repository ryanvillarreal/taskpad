# Copy this to .env and fill in values before running docker compose up.

# Public hostname Traefik will route to this service.
TASKPAD_DOMAIN=todo.example.com

# API bearer token. Generate with: openssl rand -hex 32
TASKPAD_API_KEY=changeme

# Server port (default 8080, matches the Traefik label).
PORT=8080

# CORS origins. Leave empty to disable CORS headers (recommended for CLI-only use).
# Set to the origin of your web client if you have one, e.g. https://todo.example.com
TASKPAD_CORS_ORIGINS=
